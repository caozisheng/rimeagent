{
  "name": "rimeagent",
  "version": "0.2.3",
  "private": false,
  "description": "Host-agnostic LLM agent engine with tool registry, streaming, and expert role orchestration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "dependencies": {
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "keywords": [
    "llm",
    "agent",
    "tool-calling",
    "streaming",
    "openai-compatible"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caozisheng/rimeagent.git"
  }
}
